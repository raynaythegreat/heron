FROM alpine:3.21

ARG TARGETPLATFORM

RUN apk add --no-cache ca-certificates tzdata

COPY $TARGETPLATFORM/heron /usr/local/bin/heron
COPY $TARGETPLATFORM/heron-launcher /usr/local/bin/heron-launcher

RUN addgroup -g 1000 heron && \
    adduser -D -u 1000 -G heron heron

USER heron

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -q --spider http://localhost:18800/health || exit 1

ENTRYPOINT ["heron-launcher"]
CMD ["-public", "-no-browser"]
